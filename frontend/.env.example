# Copy to .env and fill in your values. Align with backend: see ENV_ALIGNMENT.md and root env.example

# Supabase (from project settings → API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Backend API URL (no trailing slash). Must match backend BACKEND_URL. Alternative: VITE_DOMAIN (same use as process.env.DOMAIN).
VITE_API_URL=http://localhost:4000
# VITE_DOMAIN=http://localhost:4000

# Backend URL for OAuth (no trailing slash). Must match backend BACKEND_URL. Used for "Sign in with LinkedIn"
VITE_OAUTH_BACKEND_URL=http://localhost:4000

# Optional
VITE_LINKEDIN_CLIENT_ID=your-linkedin-client-id
