{
  "manifest_version": 3,
  "name": "POSTORA LinkedIn Connector",
  "version": "1.0.0",
  "description": "Connects your LinkedIn account to POSTORA automatically",
  "permissions": ["cookies", "tabs"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "http://localhost:5173/*",
    "http://localhost:3000/*",
    "https://linkedinflow.duckdns.org/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:5173/*",
        "http://localhost:3000/*",
        "https://linkedinflow.duckdns.org/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
