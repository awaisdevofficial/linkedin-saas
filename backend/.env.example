# Align with frontend: see ENV_ALIGNMENT.md and root env.example
PORT=4000
# Must match where the frontend runs (no trailing slash). Backend redirects to FRONTEND_URL/auth/login and /auth/callback
FRONTEND_URL=http://localhost:5173
# Must match frontend VITE_OAUTH_BACKEND_URL (no trailing slash)
BACKEND_URL=http://localhost:4000

LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Automation engine (run with: npm run automation or npm run dev:automation)
OPENAI_API_KEY=your_openai_api_key
# In Supabase Storage, create buckets: post-media (for generated images), logos (optional, per-user logo at {user_id}/logo.png)

# Optional: extra CORS origins (comma-separated), e.g. http://localhost:3000
# CORS_EXTRA_ORIGINS=
