# =============================================================================
# Frontend + Backend alignment — keep these in sync
# =============================================================================
# Copy the relevant blocks into frontend/.env and backend/.env (do not use one file for both).
# Frontend URL (where the React app runs) — backend uses this for redirects.
# Backend URL (where the OAuth server runs) — frontend uses this for "Sign in with LinkedIn".
#
# Local dev:
#   FRONTEND_URL = http://localhost:5173   (Vite default)
#   BACKEND_URL  = http://localhost:4000   (backend server)
#
# Production (e.g. Duck DNS):
#   FRONTEND_URL = http://your-domain.duckdns.org
#   BACKEND_URL  = http://your-domain.duckdns.org
#   VITE_OAUTH_BACKEND_URL = http://your-domain.duckdns.org
#   In LinkedIn Developer Console, set redirect URL to: http://your-domain.duckdns.org/auth/linkedin/callback
#   In Supabase Dashboard → Auth → URL Configuration: Site URL = http://your-domain.duckdns.org,
#   Redirect URLs add: http://your-domain.duckdns.org/auth/callback
# =============================================================================

# --- Frontend (frontend/.env) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Must equal BACKEND_URL below (no trailing slash)
VITE_OAUTH_BACKEND_URL=http://localhost:4000
VITE_LINKEDIN_CLIENT_ID=your-linkedin-client-id

# --- Backend (backend/.env) ---
PORT=4000
# Must equal where the frontend is served (no trailing slash)
FRONTEND_URL=http://localhost:5173
# Must equal VITE_OAUTH_BACKEND_URL above (no trailing slash)
BACKEND_URL=http://localhost:4000

LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# Optional: override LinkedIn base URLs (normally you do not change these)
# LINKEDIN_BASE_URL=https://www.linkedin.com
# LINKEDIN_API_BASE_URL=https://api.linkedin.com
# LINKEDIN_REST_BASE_URL=https://api.linkedin.com
# LINKEDIN_VOYAGER_BASE_URL=https://www.linkedin.com

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# KIE image/video generation base URL
KIE_BASE_URL=https://api.kie.ai

# Content generation (posts, comments, replies, visual prompts)
GROQ_API_KEY=your_groq_api_key

# Automation webhooks (n8n)
N8N_LIKE_COMMENT_WEBHOOK_URL=https://your-n8n-host/webhook/Like&Comment
N8N_REPLY_WEBHOOK_URL=https://your-n8n-host/webhook/reply-to-comments

# Image & video generation: users add their own KIE API key in Automation Settings.
# Get a key: https://kie.ai/api-key
